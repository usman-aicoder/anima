# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/anima?retryWrites=true&w=majority

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# MCP transport: stdio (local dev) | http (Railway production)
ANIMA_TRANSPORT=stdio

# Node environment
NODE_ENV=development
